# VishGuard Frontend — Environment Variables
# Copy this file to `.env.local` and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# NEVER commit .env.local to git.

# ─── Backend URL ──────────────────────────────────────────────────────────────
# The URL of the VishGuard Express backend.
#
# Desktop development (backend running locally):
VITE_BACKEND_URL=http://localhost:4000

# Mobile testing on the same Wi-Fi network — replace with your machine's LAN IP
# (printed by the backend on startup):
# VITE_BACKEND_URL=http://192.168.x.x:4000

# Production (Render deployment):
# VITE_BACKEND_URL=https://vishguard-backend.onrender.com
