# VishGuard Backend — Environment Variables
# Copy this file to `.env` and fill in your values.
# NEVER commit the actual .env file to git.

# ─── Gemini API Keys ──────────────────────────────────────────────────────────
# Add one or more Google AI Studio API keys, comma-separated.
# Get free keys at: https://aistudio.google.com/app/apikey
#
# The server also accepts the legacy aliases GEMINI_API_KEYS or GEMINI_API_KEY.
# Using multiple keys enables automatic rotation when a key hits its daily quota.
#
API_KEYS=your_gemini_api_key_here,optional_second_key_here

# ─── Server Port ──────────────────────────────────────────────────────────────
# The port the Express server listens on.
# Render automatically overrides this with its own PORT value.
PORT=4000
